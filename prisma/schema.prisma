generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SENIOR_ASSISTANT
  ASSISTANT
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum SaleStatus {
  POSTED
  VOIDED
}

enum Locale {
  ES @map("es")
  EN @map("en")
}

model User {
  id                 String       @id @default(uuid()) @db.Char(36)
  name               String       @db.VarChar(120)
  username           String       @db.VarChar(80)
  normalizedUsername String       @unique @map("normalized_username") @db.VarChar(80)
  email              String       @db.VarChar(254)
  normalizedEmail    String       @unique @map("normalized_email") @db.VarChar(254)
  passwordHash       String       @map("password_hash") @db.VarChar(255)
  role               Role
  status             RecordStatus @default(ACTIVE)
  preferredLocale    Locale       @default(ES) @map("preferred_locale")
  mustChangePassword Boolean      @default(false) @map("must_change_password")
  tokenVersion       Int          @default(0) @map("token_version")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  deactivatedAt      DateTime?    @map("deactivated_at")

  sessions          AuthSession[]
  createdServices   Service[]     @relation("ServiceCreatedBy")
  updatedServices   Service[]     @relation("ServiceUpdatedBy")
  createdCategories ServiceCategory[] @relation("CategoryCreatedBy")
  updatedCategories ServiceCategory[] @relation("CategoryUpdatedBy")
  createdMethods    PaymentMethod[] @relation("MethodCreatedBy")
  updatedMethods    PaymentMethod[] @relation("MethodUpdatedBy")
  createdSales      Sale[]        @relation("SaleCreatedBy")
  updatedSales      Sale[]        @relation("SaleUpdatedBy")
  voidedSales       Sale[]        @relation("SaleVoidedBy")
  auditEvents       AuditEvent[]

  @@map("users")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Char(36)
  userId           String    @map("user_id") @db.Char(36)
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(255)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  lastUsedAt       DateTime  @default(now()) @map("last_used_at")
  userAgent        String?   @map("user_agent") @db.VarChar(255)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model ServiceCategory {
  id             String       @id @default(uuid()) @db.Char(36)
  name           String       @db.VarChar(120)
  normalizedName String       @unique @map("normalized_name") @db.VarChar(120)
  description    String?      @db.VarChar(500)
  displayOrder   Int          @default(0) @map("display_order")
  status         RecordStatus @default(ACTIVE)
  createdById    String       @map("created_by") @db.Char(36)
  updatedById    String       @map("updated_by") @db.Char(36)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deactivatedAt  DateTime?    @map("deactivated_at")
  createdBy      User         @relation("CategoryCreatedBy", fields: [createdById], references: [id])
  updatedBy      User         @relation("CategoryUpdatedBy", fields: [updatedById], references: [id])
  services       Service[]

  @@index([status, displayOrder])
  @@map("service_categories")
}

model Service {
  id             String           @id @default(uuid()) @db.Char(36)
  categoryId     String?          @map("category_id") @db.Char(36)
  name           String           @db.VarChar(160)
  normalizedName String           @unique @map("normalized_name") @db.VarChar(160)
  description    String?          @db.VarChar(500)
  suggestedPrice Decimal          @map("suggested_price") @db.Decimal(12, 2)
  currency       String           @default("EUR") @db.Char(3)
  status         RecordStatus     @default(ACTIVE)
  createdById    String           @map("created_by") @db.Char(36)
  updatedById    String           @map("updated_by") @db.Char(36)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deactivatedAt  DateTime?        @map("deactivated_at")
  category       ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy      User             @relation("ServiceCreatedBy", fields: [createdById], references: [id])
  updatedBy      User             @relation("ServiceUpdatedBy", fields: [updatedById], references: [id])
  saleItems      SaleItem[]

  @@index([status, name])
  @@map("services")
}

model PaymentMethod {
  id             String       @id @default(uuid()) @db.Char(36)
  code           String       @db.VarChar(50)
  normalizedCode String       @unique @map("normalized_code") @db.VarChar(50)
  name           String       @db.VarChar(120)
  normalizedName String       @unique @map("normalized_name") @db.VarChar(120)
  description    String?      @db.VarChar(500)
  displayOrder   Int          @default(0) @map("display_order")
  status         RecordStatus @default(ACTIVE)
  createdById    String       @map("created_by") @db.Char(36)
  updatedById    String       @map("updated_by") @db.Char(36)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deactivatedAt  DateTime?    @map("deactivated_at")
  createdBy      User         @relation("MethodCreatedBy", fields: [createdById], references: [id])
  updatedBy      User         @relation("MethodUpdatedBy", fields: [updatedById], references: [id])
  salePayments   SalePayment[]

  @@index([status, displayOrder])
  @@map("payment_methods")
}

model Sale {
  id           String     @id @default(uuid()) @db.Char(36)
  folio        String     @unique @db.VarChar(32)
  businessDate DateTime   @map("business_date") @db.Date
  currency     String     @default("EUR") @db.Char(3)
  status       SaleStatus @default(POSTED)
  totalAmount  Decimal    @map("total_amount") @db.Decimal(12, 2)
  notes        String?    @db.VarChar(1000)
  createdById  String     @map("created_by") @db.Char(36)
  updatedById  String     @map("updated_by") @db.Char(36)
  voidedById   String?    @map("voided_by") @db.Char(36)
  voidReason   String?    @map("void_reason") @db.VarChar(500)
  version      Int        @default(1)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  voidedAt     DateTime?  @map("voided_at")
  createdBy    User       @relation("SaleCreatedBy", fields: [createdById], references: [id])
  updatedBy    User       @relation("SaleUpdatedBy", fields: [updatedById], references: [id])
  voidedBy     User?      @relation("SaleVoidedBy", fields: [voidedById], references: [id])
  items        SaleItem[]
  payments     SalePayment[]

  @@index([businessDate, status])
  @@index([createdById, businessDate])
  @@map("sales")
}

model SaleItem {
  id                         String  @id @default(uuid()) @db.Char(36)
  saleId                     String  @map("sale_id") @db.Char(36)
  serviceId                  String  @map("service_id") @db.Char(36)
  serviceNameSnapshot        String  @map("service_name_snapshot") @db.VarChar(160)
  quantity                   Int     @db.UnsignedSmallInt
  suggestedUnitPriceSnapshot Decimal @map("suggested_unit_price_snapshot") @db.Decimal(12, 2)
  effectiveUnitPrice         Decimal @map("effective_unit_price") @db.Decimal(12, 2)
  priceOverrideReason        String? @map("price_override_reason") @db.VarChar(300)
  lineTotal                  Decimal @map("line_total") @db.Decimal(12, 2)
  position                   Int     @default(0) @db.UnsignedSmallInt
  sale                       Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  service                    Service @relation(fields: [serviceId], references: [id])

  @@index([serviceId, saleId])
  @@map("sale_items")
}

model SalePayment {
  id                        String        @id @default(uuid()) @db.Char(36)
  saleId                    String        @map("sale_id") @db.Char(36)
  paymentMethodId           String        @map("payment_method_id") @db.Char(36)
  paymentMethodCodeSnapshot String        @map("payment_method_code_snapshot") @db.VarChar(50)
  paymentMethodNameSnapshot String        @map("payment_method_name_snapshot") @db.VarChar(120)
  amount                    Decimal       @db.Decimal(12, 2)
  reference                 String?       @db.VarChar(120)
  position                  Int           @default(0) @db.UnsignedSmallInt
  sale                      Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentMethod             PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@index([paymentMethodId, saleId])
  @@map("sale_payments")
}

model AuditEvent {
  id          String   @id @default(uuid()) @db.Char(36)
  actorUserId String?  @map("actor_user_id") @db.Char(36)
  action      String   @db.VarChar(80)
  entityType  String   @map("entity_type") @db.VarChar(80)
  entityId    String?  @map("entity_id") @db.VarChar(36)
  beforeJson  Json?    @map("before_json")
  afterJson   Json?    @map("after_json")
  requestId   String?  @map("request_id") @db.VarChar(80)
  metadata    Json?    @map("metadata_json")
  occurredAt  DateTime @default(now()) @map("occurred_at")
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([entityType, entityId])
  @@map("audit_events")
}

model IdempotencyKey {
  id             String   @id @default(uuid()) @db.Char(36)
  scope          String   @db.VarChar(80)
  keyHash        String   @map("key_hash") @db.VarChar(128)
  requestHash    String   @map("request_hash") @db.VarChar(128)
  responseStatus Int      @map("response_status")
  responseBody   Json     @map("response_body")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([scope, keyHash])
  @@map("idempotency_keys")
}
